# ChainShield Backend - Polygon Amoy (blockchain mode)
# Copy to .env and fill in values after deploying contracts

PORT=4000
NODE_ENV=development

# Polygon Amoy RPC (same as used for deployment)
WEB3_PROVIDER_URL=https://rpc-amoy.polygon.technology

# Contract addresses (from: cd contracts && npm run deploy)
DID_REGISTRY_ADDRESS=0x...
CREDENTIAL_REGISTRY_ADDRESS=0x...

# Private key for signing DID/credential transactions
# Can be same as DEPLOYER_PRIVATE_KEY or a dedicated issuer wallet
ISSUER_PRIVATE_KEY=0x...

# JWT secret (change in production)
JWT_SECRET=your_jwt_secret_here

# --- IPFS via Pinata -------------------------------------------------
# When either PINATA_JWT or (PINATA_API_KEY + PINATA_API_SECRET) is set,
# credential payloads are pinned to IPFS on issuance and the on-chain
# `ipfsHash` field becomes `ipfs://<cid>`. If neither is set we fall
# back to a deterministic `sha256:<hex>` content hash (no IPFS upload).
#
# Recommended: create a Pinata account (free tier, 1 GB) and generate
# a JWT with `pinJSONToIPFS` permission.
# PINATA_JWT=eyJhbGciOi...
#
# Legacy key-pair auth (alternative to JWT):
# PINATA_API_KEY=
# PINATA_API_SECRET=
#
# Optional public gateway override (defaults to the Pinata gateway):
# IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
