# ChainShield Frontend
# Copy to .env.local for local overrides

# API URL (default: http://localhost:4000/api)
# VITE_API_BASE_URL=http://localhost:4000/api

# App URL for QR codes - REQUIRED for phone scanning!
# When deployed, set to your public URL so QR codes work when scanned from phones.
# Example: VITE_APP_URL=https://chainshield.vercel.app
# VITE_APP_URL=
